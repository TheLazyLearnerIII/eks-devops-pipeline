# Local directory for data/plugins
.terraform/

# Include override files given they are used for local overriding
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all variable files with secrets by default
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include microcode prediction files
.terraform.rc
terraform.rc


